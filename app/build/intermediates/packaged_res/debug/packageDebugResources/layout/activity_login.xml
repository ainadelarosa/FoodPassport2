<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F0A9">

    <!-- Logo esquina superior derecha -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_marginTop="16dp"
        android:layout_marginRight="16dp"
        android:src="@drawable/logo_foodpassport"
        android:scaleType="fitCenter"
        android:contentDescription="FoodPassport Logo"/>

    <!-- Tarjeta login -->
    <LinearLayout
        android:id="@+id/group_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:orientation="vertical"
        android:background="@drawable/bg_login_card"
        android:padding="32dp">

        <!-- Label Usuario -->
        <TextView
            android:id="@+id/usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuario"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp"/>

        <!-- Campo Usuario -->
        <EditText
            android:id="@+id/input_usuario"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:inputType="text"
            android:layout_marginBottom="20dp"/>

        <!-- Label Contraseña -->
        <TextView
            android:id="@+id/contrase_a"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp"/>

        <!-- Campo Contraseña -->
        <EditText
            android:id="@+id/input_contrasena"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="32dp"/>

        <!-- Botón Continuar -->
        <Button
            android:id="@+id/btn_continuar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continuar"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/rectangle_3"
            android:layout_marginBottom="14dp"/>

        <!-- Botón Registrarse -->
        <Button
            android:id="@+id/btn_registrarse"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Registrarse"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/rectangle_6"/>

    </LinearLayout>

</RelativeLayout>