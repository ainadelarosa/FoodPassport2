<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5DC">

    <EditText
        android:id="@+id/searchBarCountryList"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="#FFFFFF"
        android:hint="Buscar país..."
        android:inputType="text"
        android:paddingStart="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabVisited"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✅ Visitados"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tabWantToVisit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🌍 Quiero visitar"
            android:textSize="15sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <TextView
        android:id="@+id/countryCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:gravity="center"
        android:textColor="#9E0202"
        android:textSize="13sp"/>

    <ListView
        android:id="@+id/listViewCountryList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:dividerHeight="1dp"/>

</LinearLayout>